# -------------------------------------------------------------------
# Production .env template for DreamHost deployment.
# Copy to .env on the server, then fill in the blanks. Run
# `php artisan key:generate` once on first deploy to populate APP_KEY.
# -------------------------------------------------------------------

APP_NAME="Florida Chautauqua Theater"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://volunteer.floridachautauqua.com
APP_VERSION=dev

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=America/New_York

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# DreamHost MySQL — fill in from the panel (Goodies > MySQL Databases).
# DB_HOST is the theater's shared MySQL host; DB_DATABASE /
# _USERNAME / _PASSWORD come from the specific DB you create there.
DB_CONNECTION=mysql
DB_HOST=mysql.floridachautauqua.com
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=1440
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Mail — SendGrid is the plan. Create an API key with "Mail Send" only,
# paste it into MAIL_PASSWORD, username stays literally "apikey".
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="volunteers@floridachautauqua.com"
MAIL_FROM_NAME="Florida Chautauqua Theater"

# Twilio — required only if any notification_schedule uses channel 'sms'
# or 'both'. Leave empty for email-only deployments. TWILIO_FROM must be
# a Twilio-verified number in E.164 format (+15551234567).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

VITE_APP_NAME="${APP_NAME}"
